{
  "name": "@chatcore/cli",
  "version": "0.1.0",
  "description": "Command-line tools for ChatCore.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/good-jinu/chatcore.git",
    "directory": "packages/cli"
  },
  "bin": {
    "chatcore": "./dist/cli.mjs"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "lint:package": "publint",
    "lint:types": "attw --profile esm-only --pack .",
    "typecheck": "tsc --project tsconfig.json"
  },
  "dependencies": {
    "kysely": "^0.29.2",
    "unadapter": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:vitest"
  }
}
